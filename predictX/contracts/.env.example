# === PDX 合约部署配置 ===

# 你的钱包私钥 (不要泄露！不要提交到 git！)
PRIVATE_KEY=0x你的私钥

# Base Sepolia RPC URL (从 Alchemy 获取)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/你的API_KEY

# BaseScan API Key (用于验证合约源码, 可选)
BASESCAN_API_KEY=你的BASESCAN_KEY

# === 部署后填写 (Deploy.s.sol 会输出这些地址) ===
MOCK_USDC=0x部署后的地址
PDX_MARKET=0x部署后的地址
PDX_ORACLE=0x部署后的地址
