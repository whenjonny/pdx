# Blockchain (Base Sepolia testnet)
RPC_URL=http://localhost:8545
CHAIN_ID=84532

# Contract addresses (fill after deployment)
PDX_MARKET_ADDRESS=
MOCK_USDC_ADDRESS=
PDX_ORACLE_ADDRESS=

# Deployer private key (anvil account 0 for local dev, your key for testnet)
# DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# IPFS / Pinata (optional — uses mock if empty)
# Register free at https://www.pinata.cloud
PINATA_API_KEY=
PINATA_SECRET_KEY=

# MiroFish prediction engine
# true = mock mode (noise on AMM price), false = scheduled analysis
USE_MOCK_MIROFISH=true

# MiroFish LLM settings (only used when USE_MOCK_MIROFISH=false)
# Empty API key = heuristic fallback (no LLM needed)
# Supports any OpenAI-compatible API (OpenAI, DeepSeek, local Ollama, etc.)
MIROFISH_LLM_API_KEY=
MIROFISH_LLM_BASE_URL=https://api.openai.com/v1
MIROFISH_LLM_MODEL=gpt-4o-mini
MIROFISH_INTERVAL_SECONDS=300

# Server
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
